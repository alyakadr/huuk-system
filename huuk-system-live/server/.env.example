# Add these to your .env file to handle SMS service limitations

# SMS Service Configuration
SMS_MODE=console # Options: console, textbelt, email, twilio
SMS_DISABLED=false # Set to true to disable SMS sending but still log attempts
NODE_ENV=development # This will make SMS service log to console instead of sending

# Twilio Configuration (if using Twilio)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Email Configuration
GMAIL_USER=your_email@gmail.com
GMAIL_PASS=your_app_password

# Database Configuration
DB_HOST=db.ruzentra.com
DB_USER=ruzentra_huukbarber
DB_PASSWORD=huukbarber02@
DB_DATABASE=ruzentra_huukbarber
