{
  "name": "huuk-system",
  "version": "0.1.0",
  "private": true,
  "description": "HUUK Booking Management System – monorepo root",
  "scripts": {
    "install:all": "npm install --prefix server && npm install --prefix client",
    "start": "concurrently --names \"server,client\" --prefix-colors \"cyan,magenta\" \"npm run start:server\" \"npm run start:client\"",
    "start:server": "npm start --prefix server",
    "start:client": "npm run react-start --prefix client",
    "dev": "concurrently --names \"server,client\" --prefix-colors \"cyan,magenta\" \"npm run dev:server\" \"npm run start:client\"",
    "dev:server": "npm run dev --prefix server",
    "build:client": "npm run build --prefix client"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
